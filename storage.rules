rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{allPaths=**} {
      allow read: if request.auth != null; // Only staff can read
      allow write: if true; // Allow portal users to upload
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
